{
  "$schema": "https://claude.ai/schemas/settings.json",
  "description": "Claude Code 글로벌 설정 (jh941213 + affaan-m 통합)",
  "version": "1.0.0",

  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo rm *)",
      "Bash(chmod 777 *)",
      "Bash(:(){ :|:& };:)"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "name": "session-start",
        "command": "node ~/.claude/hooks/session-start.js"
      }
    ],
    "SessionEnd": [
      {
        "name": "session-end",
        "command": "node ~/.claude/hooks/session-end.js"
      }
    ],
    "PreToolUse": [
      {
        "name": "pre-edit-check",
        "matcher": "Edit",
        "command": "node ~/.claude/hooks/pre-edit-check.js"
      },
      {
        "name": "git-push-review",
        "matcher": "Bash",
        "pattern": "git push",
        "command": "node ~/.claude/hooks/git-push-review.js"
      },
      {
        "name": "documentation-guard",
        "matcher": "Write",
        "pattern": "\\.md$",
        "command": "node ~/.claude/hooks/documentation-guard.js"
      }
    ],
    "PostToolUse": [
      {
        "name": "post-edit-lint",
        "matcher": "Edit",
        "pattern": "\\.(ts|tsx)$",
        "command": "node ~/.claude/hooks/post-edit-lint.js"
      }
    ],
    "PreCompact": [
      {
        "name": "pre-compact",
        "command": "node ~/.claude/hooks/pre-compact.js"
      },
      {
        "name": "compaction-warning",
        "command": "node ~/.claude/hooks/compaction-warning.js"
      }
    ]
  },

  "agents": {
    "maxConcurrent": 3,
    "defaultTimeout": 300000
  },

  "context": {
    "warningThreshold": 70000,
    "criticalThreshold": 85000,
    "autoCompactThreshold": 95000
  },

  "automation": {
    "autoDelegate": true,
    "autoVerifyAfterEdit": true,
    "autoSecurityScan": true
  }
}
