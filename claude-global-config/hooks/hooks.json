{
  "$schema": "https://claude.ai/schemas/hooks.json",
  "description": "Claude Code 글로벌 Hooks 설정",
  "version": "1.0.0",

  "hooks": {
    "SessionStart": [
      {
        "name": "session-start",
        "description": "HANDOFF 확인 및 프로젝트 감지",
        "command": "node ~/.claude/hooks/session-start.js"
      }
    ],

    "SessionEnd": [
      {
        "name": "session-end",
        "description": "세션 종료 시 상태 저장 안내",
        "command": "node ~/.claude/hooks/session-end.js"
      }
    ],

    "PreToolUse": [
      {
        "name": "pre-edit-check",
        "description": "코드 편집 전 보안 및 품질 검사",
        "matcher": "Edit",
        "command": "node ~/.claude/hooks/pre-edit-check.js"
      },
      {
        "name": "git-push-review",
        "description": "git push 전 확인",
        "matcher": "Bash",
        "pattern": "git push",
        "command": "node ~/.claude/hooks/git-push-review.js"
      },
      {
        "name": "documentation-guard",
        "description": "불필요한 문서 생성 방지",
        "matcher": "Write",
        "pattern": "\\.md$",
        "command": "node ~/.claude/hooks/documentation-guard.js"
      }
    ],

    "PostToolUse": [
      {
        "name": "post-edit-lint",
        "description": "TypeScript 파일 편집 후 타입 체크",
        "matcher": "Edit",
        "pattern": "\\.(ts|tsx)$",
        "command": "node ~/.claude/hooks/post-edit-lint.js"
      }
    ],

    "PreCompact": [
      {
        "name": "pre-compact",
        "description": "압축 전 상태 저장",
        "command": "node ~/.claude/hooks/pre-compact.js"
      },
      {
        "name": "compaction-warning",
        "description": "압축 경고 메시지",
        "command": "node ~/.claude/hooks/compaction-warning.js"
      }
    ]
  }
}
